# ──────────────────────────────────────────────────────────────
# Smart Diet API — Environment Variables
# Copy this file to .env and fill in real values before running.
# ──────────────────────────────────────────────────────────────

# JWT signing secret (minimum 32 characters, keep secret!)
JWT_SECRET=replace_with_a_long_random_secret_minimum_32_chars

# JWT issuer / audience (can remain as-is)
JWT_ISSUER=SmartDietApi
JWT_AUDIENCE=SmartDietApp

# URL of the Python/FastAPI ML service
ML_SERVICE_URL=http://localhost:8000

# SQLite file path (relative to the SmartDietApi directory)
DATABASE_PATH=smartdiet.db
